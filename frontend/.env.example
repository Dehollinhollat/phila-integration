# ─── API Backend ─────────────────────────────────────────────────────────────
# URL de l'API backend — inclure le chemin /api, sans slash final
# Pour tester sur téléphone sur le réseau local, remplacer localhost par l'IP de la machine
# ex: VITE_API_URL=http://localhost:4000/api
VITE_API_URL=http://localhost:4000/api #Normalement ici c'est 

# ─── Cloudflare Turnstile ─────────────────────────────────────────────────────
# Clé publique Turnstile (sitekey) — visible côté client, pas un secret
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
