{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir":                       "./dist",
    "rootDir":                      ".",
    "noEmit":                       false,
    "allowImportingTsExtensions":   false,
    "moduleResolution":             "node16",
    "module":                       "node16"
  },
  "include": ["src/**/*", "generated/**/*"],
  "exclude": ["node_modules", "dist", "src/__tests__"]
}
