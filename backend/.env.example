# ─── Base de données ──────────────────────────────────────────────────────────
# URL de connexion PostgreSQL (Neon, Supabase, ou instance locale)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Clé secrète HMAC-SHA256 — min 64 caractères recommandés
# Générer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_random_secret_at_least_64_characters_long

# ─── Twilio WhatsApp ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Resend (emails transactionnels — réinitialisation mot de passe) ─────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cloudflare Turnstile ─────────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Frontend (utilisé dans les liens des emails envoyés par le backend) ──────
# Développement local :
FRONTEND_URL=http://localhost:5173
# Production :
# FRONTEND_URL=https://votre-domaine.com
